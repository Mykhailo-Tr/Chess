SECRET_KEY=change-this-in-production

# Lichess OAuth2 credentials
LICHESS_CLIENT_ID=your_lichess_client_id
LICHESS_CLIENT_SECRET=your_lichess_client_secret

# OAuth and API endpoints
LICHESS_OAUTH_AUTHORIZE_URL=https://lichess.org/oauth
LICHESS_OAUTH_TOKEN_URL=https://lichess.org/api/token
LICHESS_API_BASE=https://lichess.org/api

# Local default: SQLite
DATABASE_URL=sqlite:///chess_behavioral.db

# For production (Railway / Render), use a PostgreSQL URL:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

FLASK_ENV=development
SESSION_COOKIE_SECURE=0
REMEMBER_COOKIE_SECURE=0

# Optional future extension placeholders
REDIS_URL=
ENABLE_BACKGROUND_JOBS=0
